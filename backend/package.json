{
  "name": "backend",
  "module": "index.ts",
  "extends": "../tsconfig.base.json",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run typecheck && bun build index.ts --outdir dist --target bun",
    "dev": "bun --watch index.ts",
    "db:migration:fix-latest": "bun scripts/fix-latest-migration.ts",
    "db:migration:generate": "bun scripts/generate-migration.ts",
    "db:migration:run": "bunx --bun typeorm migration:run -d src/data-source.ts",
    "db:migration:revert": "bunx --bun typeorm migration:revert -d src/data-source.ts",
    "typecheck": "tsc -b",
    "start": "bun index.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/express": "^5.0.6",
    "@types/supertest": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.1.1",
    "typeorm": "^0.3.28"
  }
}
